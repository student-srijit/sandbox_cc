{
  "name": "bhool-bhulaiyaa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-all-servers.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "web3:compile": "hardhat compile",
    "web3:test": "hardhat test",
    "web3:sync-env": "node scripts/web3/sync-env.js",
    "web3:validate:sepolia": "node scripts/web3/validate.js --network sepolia",
    "web3:validate:celo-sepolia": "node scripts/web3/validate.js --network celoSepolia",
    "web3:validate:alfajores": "npm run web3:validate:celo-sepolia",
    "web3:deploy:sepolia": "hardhat run scripts/web3/deploy.js --network sepolia && npm run web3:validate:sepolia && npm run web3:sync-env",
    "web3:deploy:celo-sepolia": "hardhat run scripts/web3/deploy.js --network celoSepolia && npm run web3:validate:celo-sepolia && npm run web3:sync-env",
    "web3:deploy:teststable:celo-sepolia": "hardhat run scripts/web3/deploy-teststable.js --network celoSepolia",
    "web3:deploy:teststable:alfajores": "npm run web3:deploy:teststable:celo-sepolia",
    "web3:deploy:alfajores": "npm run web3:deploy:celo-sepolia",
    "web3:deploy:all": "npm run web3:deploy:sepolia && npm run web3:deploy:alfajores",
    "web3:verify:sepolia": "hardhat verify --network sepolia",
    "web3:verify:celo-sepolia": "hardhat verify --network celoSepolia",
    "web3:verify:alfajores": "npm run web3:verify:celo-sepolia"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.2.0",
    "ethers": "^6.16.0",
    "leaflet": "^1.9.4",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^16.6.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "hardhat": "^2.24.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
