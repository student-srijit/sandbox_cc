# Change SECRET_KEY to a secure random string in production
SECRET_KEY=

# Default Admin Credentials
# USERNAME: bhool
ADMIN_USER=
# PASSWORD: bhulaiyaa2026 (hashed via PBKDF2)
ADMIN_PASS_HASH=

# EVM Deployer
DEPLOYER_PRIVATE_KEY=
ADMIN_ADDRESS=
TREASURY_ADDRESS=
STABLE_TOKEN_ADDRESS=

# Networks
SEPOLIA_RPC_URL=
CELO_ALFAJORES_RPC_URL=
CELO_SEPOLIA_RPC_URL=

# Verifiers
ETHERSCAN_API_KEY=
CELOSCAN_API_KEY=

# Pinata
PINATA_JWT=
PINATA_GATEWAY=

# Cloudinary (signed upload for bounty evidence)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Internal RPC trust boundary (Next.js -> FastAPI)
INTERNAL_RPC_SHARED_SECRET=
REQUIRE_INTERNAL_RPC_SIGNATURE=true
INTERNAL_RPC_SIGNATURE_MAX_SKEW_SECONDS=90

# Backend abuse protection
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=8
ADMIN_RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT_MAX_REQUESTS=90
RPC_RATE_LIMIT_WINDOW_SECONDS=60
RPC_RATE_LIMIT_MAX_REQUESTS=180

# IP Fail2ban auto-blocking
# IPs that hit rate limits this many times get temporarily banned
IP_BAN_THRESHOLD_STRIKES=3
# Short ban duration in seconds (triggered at 3+ strikes)
IP_BAN_DURATION_SHORT_SECONDS=600
# Long ban duration in seconds (triggered at 10+ strikes)
IP_BAN_DURATION_LONG_SECONDS=3600

# TOTP 2FA for admin login (Google Authenticator)
# Generate with: python -c "import pyotp; print(pyotp.random_base32())"
# Visit /ops/login and enter this as your authenticator secret
TOTP_SECRET=

# Service account key for internal server-to-server auth (bypasses TOTP)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
BACKEND_SERVICE_KEY=

# Frontend runtime contract addresses (filled after deployment)
NEXT_PUBLIC_SEPOLIA_EVIDENCE_ATTESTATION=
NEXT_PUBLIC_SEPOLIA_REPORT_ACCESS_NFT=
NEXT_PUBLIC_SEPOLIA_ENTERPRISE_LICENSE_NFT=
NEXT_PUBLIC_SEPOLIA_BOUNTY_ESCROW=
NEXT_PUBLIC_SEPOLIA_STABLE_TOKEN=

NEXT_PUBLIC_CELO_EVIDENCE_ATTESTATION=
NEXT_PUBLIC_CELO_REPORT_ACCESS_NFT=
NEXT_PUBLIC_CELO_ENTERPRISE_LICENSE_NFT=
NEXT_PUBLIC_CELO_BOUNTY_ESCROW=
NEXT_PUBLIC_CELO_STABLE_TOKEN=